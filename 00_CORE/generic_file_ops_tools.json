[
  {
    "type": "function",
    "function": {
      "name": "read_md",
      "description": "Read a Markdown file from the configured local vault.",
      "parameters": {
        "type": "object",
        "properties": {
          "relative_path": {
            "type": "string",
            "description": "Path to the Markdown file relative to the vault root."
          }
        },
        "required": ["relative_path"],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "append_md",
      "description": "Append Markdown content to a file, creating it if needed.",
      "parameters": {
        "type": "object",
        "properties": {
          "relative_path": {
            "type": "string",
            "description": "Path to the Markdown file relative to the vault root."
          },
          "content": {
            "type": "string",
            "description": "Markdown content to append."
          },
          "create": {
            "type": "boolean",
            "description": "Whether to create the file if it does not exist.",
            "default": true
          }
        },
        "required": ["relative_path", "content"],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "write_md",
      "description": "Write a Markdown file. By default, refuse to overwrite existing files.",
      "parameters": {
        "type": "object",
        "properties": {
          "relative_path": {
            "type": "string",
            "description": "Path to the Markdown file relative to the vault root."
          },
          "content": {
            "type": "string",
            "description": "Markdown content to write."
          },
          "overwrite": {
            "type": "boolean",
            "description": "Whether to overwrite an existing file.",
            "default": false
          }
        },
        "required": ["relative_path", "content"],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "search_local",
      "description": "Search Markdown files in the local vault for a text query.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search text."
          },
          "glob_pattern": {
            "type": "string",
            "description": "Glob pattern to restrict search.",
            "default": "**/*.md"
          },
          "case_sensitive": {
            "type": "boolean",
            "description": "Whether search should be case-sensitive.",
            "default": false
          },
          "max_results": {
            "type": "integer",
            "description": "Maximum files to return.",
            "default": 25,
            "minimum": 1,
            "maximum": 100
          }
        },
        "required": ["query"],
        "additionalProperties": false
      }
    }
  }
]
